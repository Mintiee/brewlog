# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# migration backups (DB dumps — not source)
/scripts/backup-*.json

# python script caches
__pycache__/
*.pyc

# local-only dev artifacts (kept out of the release repo)
/audit/
/design_handoff_brew_app/

# local-only docs / AI instructions (kept out of the release repo)
/AGENTS.md
/CLAUDE.md
/DEPLOY.md
/docs/ai/self-improve/

# typescript
*.tsbuildinfo
next-env.d.ts
